{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@openuidev/lang-core": ["../../packages/lang-core/src"],
      "@openuidev/react-lang": ["../../packages/react-lang/src"],
      "@openuidev/react-ui-dsl": ["../../packages/react-ui-dsl/src"]
    }
  },
  "include": ["src"]
}