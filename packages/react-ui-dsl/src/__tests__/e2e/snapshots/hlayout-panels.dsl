root = Stack([panels])
panels = Stack([leftPanel, rightPanel], "row", "l")
leftPanel = Card([welcomeTitle, welcomeText], "card", "full")
welcomeTitle = Text("Welcome", "large")
welcomeText = Text("This is the left panel with some introductory content.")
rightPanel = Card([statsTitle, statsDescription], "card", "full")
statsTitle = Text("Quick Stats", "large")
statsDescription = Descriptions([itemsField, usersField, activeField], null, null, 1)
itemsField = DescField("Total Items", 42)
usersField = DescField("Active Users", 128)
activeField = DescField("Uptime", "99.9%")