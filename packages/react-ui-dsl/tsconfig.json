{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.json",
  "include": ["src/**/*"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"],
  "compilerOptions": {
    "baseUrl": ".",
    "moduleResolution": "bundler",
    "module": "ESNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "paths": {
      "@openuidev/react-ui-dsl": ["./src/index.ts"],
      "@openuidev/react-lang": ["../react-lang/src/index.ts"],
      "@openuidev/lang-core": ["../lang-core/src/index.ts"]
    }
  }
}
