{
  "name": "@openuidev/react-ui-dsl",
  "version": "0.1.0",
  "type": "module",
  "description": "DSL component library built on Ant Design v5 and ECharts",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "postinstall": "playwright install chromium",
    "test": "cross-env REGEN_SNAPSHOTS=0 vitest run --config vitest.config.ts",
    "test:eview": "cross-env REACT_UI_DSL_VIEW_TARGET=eview REGEN_SNAPSHOTS=0 vitest run --config vitest.config.ts",
    "test:e2e": "cross-env REGEN_SNAPSHOTS=0 vitest run src/__tests__/e2e",
    "test:e2e:report": "node ./src/__tests__/e2e/report-cli.mjs",
    "test:e2e:regen": "cross-env REGEN_SNAPSHOTS=1 vitest run src/__tests__/e2e",
    "test:e2e:regen:fixture": "cross-env REGEN_SNAPSHOTS=1 vitest run src/__tests__/e2e/dsl-e2e.test.tsx",
    "test:fuzz": "cross-env REGEN_SNAPSHOTS=0 REACT_UI_DSL_E2E_SUITE=fuzz vitest run src/__tests__/e2e/dsl-fuzz.test.tsx",
    "test:fuzz:report": "node ./src/__tests__/e2e/report-cli.mjs --fuzz",
    "test:fuzz:regen": "cross-env REGEN_SNAPSHOTS=1 REACT_UI_DSL_E2E_SUITE=fuzz vitest run src/__tests__/e2e/dsl-fuzz.test.tsx",
    "report:view": "npx serve ./src/__tests__/e2e/reports",
    "eval": "tsx --import ./src/__tests__/e2e/css-stub-loader.mjs ./src/__tests__/e2e/eval-loop.ts",
    "build": "tsdown",
    "build:eview": "cross-env REACT_UI_DSL_VIEW_TARGET=eview tsdown",
    "build:eview:publish": "cross-env REACT_UI_DSL_VIEW_TARGET=eview REACT_UI_DSL_BUILD_MODE=publish tsdown",
    "publish:eview": "tsx ./scripts/publish-eview.mts",
    "watch": "tsdown --watch",
    "storybook": "storybook dev -p 6007",
    "storybook:eview": "cross-env REACT_UI_DSL_VIEW_TARGET=eview storybook dev -p 6007",
    "build:storybook": "storybook build",
    "pretypecheck": "pnpm --dir ../react-lang build",
    "typecheck": "tsc --noEmit",
    "lint:check": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "format:fix": "prettier --write ./src",
    "format:check": "prettier --check ./src",
    "check:publint": "publint",
    "check:attw": "attw --pack .",
    "prepare": "pnpm run build",
    "prepublishOnly": "pnpm run check:publint && pnpm run check:attw",
    "ci": "pnpm run lint:check && pnpm run format:check"
  },
  "keywords": [
    "openui",
    "generative-ui",
    "react",
    "llm",
    "streaming",
    "renderer",
    "parser",
    "ai",
    "components",
    "prompt-generation",
    "zod",
    "ui-generation",
    "model-driven-ui",
    "openui-lang",
    "dsl",
    "antd",
    "echarts"
  ],
  "homepage": "https://openui.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/thesysdev/openui.git",
    "directory": "packages/react-ui-dsl"
  },
  "bugs": {
    "url": "https://github.com/thesysdev/openui/issues"
  },
  "author": "engineering@thesys.dev",
  "dependencies": {
    "echarts": "^5.0.0",
    "github-markdown-css": "5.8.1",
    "highlight.js": "11.11.1",
    "marked": "15.0.7",
    "xss": "1.0.15"
  },  
  "peerDependencies": {
    "@openuidev/react-lang": "workspace:^",
    "antd": "^5.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "zod": "^4.3.6"
  },
  "peerDependenciesMeta": {
    "react-markdown": {
      "optional": true
    }
  },
  "devDependencies": {
    "@openuidev/react-lang": "workspace:^",
    "@storybook/addon-essentials": "^8.5.3",
    "@storybook/addon-interactions": "^8.5.3",
    "@storybook/blocks": "^8.5.3",
    "@storybook/react": "^8.5.3",
    "@storybook/react-vite": "^8.5.3",
    "@storybook/test": "^8.5.3",
    "@testing-library/react": "^16.3.0",
    "@tsdown/css": "0.21.7",
    "@types/node": "^22.12.0",
    "@types/react": ">=19.0.0",
    "@types/react-dom": ">=19.0.0",
    "antd": "^5.0.0",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "echarts": "^5.0.0",
    "https-proxy-agent": "^9.0.0",
    "jsdom": "^29.1.1",
    "openai": "^4.93.0",
    "playwright": "1.59.1",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "react-markdown": "^10.1.0",
    "storybook": "^8.5.3",
    "tsx": "^4.19.0",
    "vite": "^5.0.0",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  }
}
